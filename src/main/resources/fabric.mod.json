{
  "schemaVersion": 1,
  "id": "hyprrank",
  "version": "${version}",
  "name": "HyprRank",
  "description": "Remplace les noms de rank par des glyphes (images ou texte coloré)",
  "authors": ["Satanas1275"],
  "contact": {
    "sources": "https://github.com/Satanas1275/HyprRank",
    "issues": "https://github.com/Satanas1275/HyprRank/issues"
  },
  "license": "CC-BY-NC-4.0",
  "icon": "assets/hyprrank/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": ["com.hyprank.HyprRank"],
    "client": ["com.hyprank.HyprRankClient"]
  },
  "mixins": ["hyprrank.mixins.json"],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": ">=${minecraft_version}",
    "fabric-api": ">=${fabric_version}",
    "java": ">=${java_version}"
  }
}
